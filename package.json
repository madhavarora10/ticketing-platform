{
  "name": "ticketing-platform-monorepo",
  "description": "Dynamic event ticketing platform with intelligent pricing",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:seed": "pnpm --filter @repo/database db:seed",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "test": "pnpm --filter api test",
    "test:pricing": "pnpm --filter @repo/pricing test"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}